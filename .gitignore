# Autotools generated (vendored source)
# NOTE: `configure`, `Makefile.in`, `aclocal.m4` are SHIPPED IN THE
# TARBALL as source files; they are NOT gitignored. The wdiff bundle's
# autotools regenerate them at build time, but the dwdiff bundle
# keeps the hand-written versions in the tarball — those MUST be
# tracked, otherwise CI has no `configure` to run.
INSTALL
autom4te.cache/
autotools/
compile
config.guess
config.h.in
config.h.in~
config.log
config.status
config.sub
depcomp
install-sh
libtool
ltmain.sh
missing
test-driver
stamp-h1
# `Makefile` is the file generated by `./configure` (substitute of
# Makefile.in). `Makefile.in` is the input and is tracked above.
Makefile

